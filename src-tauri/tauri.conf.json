{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "音觅",
  "version": "0.1.0",
  "identifier": "io.github.xiaobing6.yinmi",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "音觅",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 480
      }
    ],
    "security": {
      "capabilities": ["main-capability"],
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJERjI5QjUxNDM5QzdGMEMKUldRTWY1eERVWnZ5TGNwemc4eXRKMlI4OURKMXY1NGtyQkFnNkJxNk5PUldZazhXc0kxa2NSRCsK",
      "endpoints": [
        "https://github.com/xiaobing6/yinmi-desktop/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "windows": { "webviewInstallMode": { "type": "embedBootstrapper" } },
    "macOS": { "minimumSystemVersion": "13.3" }
  }
}
